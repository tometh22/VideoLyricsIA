# -------------------------------------------------------------------
# VideoLyricsIA backend environment
# -------------------------------------------------------------------
# Copy to `.env` and fill in the real values. Never commit `.env`.

# Environment: dev | prod | production | test. In prod, JWT_SECRET y
# OPENAI_API_KEY deben estar setteados o el API se niega a bootear.
ENV=dev
ENVIRONMENT=dev

# -------------------------------------------------------------------
# OpenAI (Whisper transcription + lyric metadata)
# -------------------------------------------------------------------
# CRÍTICO en prod: el API rompe al boot si esta var no está seteada
# cuando ENV=prod o ENVIRONMENT=production (ver auth.py:95-98). Sin
# estar acá costaba debugging cuando faltaba.
OPENAI_API_KEY=

# -------------------------------------------------------------------
# Google Vertex AI (Veo 3 + Imagen 4 + Gemini)
# -------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=vertex_credentials.json
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
# Gemini API key (fallback de Vertex). Solo Vertex → dejá vacío.
GEMINI_API_KEY=

# -------------------------------------------------------------------
# YouTube OAuth (optional; only needed for /youtube/upload)
# -------------------------------------------------------------------
YOUTUBE_TOKEN_PATH=youtube_token.json
YOUTUBE_OAUTH_PATH=youtube_oauth.json

# -------------------------------------------------------------------
# Authentication
# -------------------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
ADMIN_PASSWORD=change-this-too

# -------------------------------------------------------------------
# Database (Postgres)
# -------------------------------------------------------------------
# Default: sqlite local. En prod debe ser Postgres.
DATABASE_URL=sqlite:///./lyricgen.db
# Pool tuning. 8 connections × N workers vs Postgres 100 max.
DB_POOL_SIZE=8
DB_MAX_OVERFLOW=8

# -------------------------------------------------------------------
# Job queue (Redis + RQ)
# -------------------------------------------------------------------
# Sin este, el API hace fallback a in-process threads (dev only).
REDIS_URL=redis://localhost:6379/0

# Worker tuning
JOB_TIMEOUT_SECONDS=2700              # 45 min (YouTube delivery)
JOB_TIMEOUT_UMG_SECONDS=5400          # 90 min para delivery_profile=umg/both
JOB_RESULT_TTL_SECONDS=86400          # 24 h
JOB_FAILURE_TTL_SECONDS=604800        # 7 d
PRORES_PREWARM_TIMEOUT_SECONDS=900    # 15 min para transcode lazy
WORKER_MAX_JOBS=                      # rotate workers cada N jobs (anti-leak)

# Pipeline retry on worker death (RQ Retry):
PIPELINE_RETRY_MAX=1                  # 1 retry tras worker SIGKILL
PIPELINE_RETRY_INTERVAL_S=30

# -------------------------------------------------------------------
# ProRes / broadcast delivery (UMG)
# -------------------------------------------------------------------
# Comma-separated lowercase tenant_ids autorizados a pedir delivery
# ProRes. Admin role bypassa este allowlist.
PRORES_TENANTS=umg
# Pre-warm ProRes ni bien termina el render MP4 (en lugar de lazy
# on first /download). Best-effort — si cola saturada, skipea.
PRORES_PREWARM=1
PRORES_PREWARM_MAX_QUEUE_DEPTH=15

# -------------------------------------------------------------------
# Cloud storage (Cloudflare R2)
# -------------------------------------------------------------------
# Sin esto, los deliverables quedan en disco local y /download
# streama por el API (lento para archivos grandes; OK para dev).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=videolyricsia-masters

# Direct-to-R2 upload tuning (presigned PUT)
MULTIPART_THRESHOLD_BYTES=16777216    # 16 MB → switch single → multipart
MULTIPART_PART_SIZE_BYTES=8388608     # 8 MB per part
PRESIGN_PUT_TTL_S=900                 # presigned URL TTL

# -------------------------------------------------------------------
# Observability
# -------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO
HEALTH_STARTUP_GRACE_S=20             # /health returns "starting" durante cold boot

# -------------------------------------------------------------------
# CORS
# -------------------------------------------------------------------
# Comma-separated allowlist. Empty = allow all (dev).
CORS_ORIGINS=

# -------------------------------------------------------------------
# Rate limiting
# -------------------------------------------------------------------
RATE_LIMIT_ENABLED=true

# -------------------------------------------------------------------
# Upload limits
# -------------------------------------------------------------------
MAX_UPLOAD_MB=50

# -------------------------------------------------------------------
# Google Drive OAuth (botón "Guardar en Drive")
# -------------------------------------------------------------------
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# Client ID (Web Application). Authorized redirect URIs debe matchear
# GOOGLE_OAUTH_REDIRECT_URI. Scope que pide la app: `drive.file`
# (limitado a archivos creados por la app — no requiere Google app
# verification, podemos shippear sin esperar review).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Ejemplo prod: https://genly-ai.up.railway.app/drive/callback
# Ejemplo staging: https://api-staging-9b82.up.railway.app/drive/callback
GOOGLE_OAUTH_REDIRECT_URI=

# Fernet key para encriptar refresh_tokens de Drive en DB.
# Generala con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Si rotás la key, todos los users tienen que reconectar Drive
# (los tokens viejos quedan ilegibles).
DRIVE_TOKEN_ENCRYPTION_KEY=

# Canary allowlist para la integración Drive. Lista de tenant_ids
# separados por coma (e.g. "umg,warner"). Vacío = SOLO admin tiene
# acceso. Mismo patrón que PRORES_TENANTS: cambia sin redeploy de
# código. Cuando UMG/Warner u otro tenant esté listo para probar,
# se agrega su tenant_id acá y ven el botón "Guardar en Drive".
DRIVE_ENABLED_TENANTS=

# -------------------------------------------------------------------
# Email (transactional via Brevo)
# -------------------------------------------------------------------
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@example.com
BREVO_SENDER_NAME=GenLy
# Staging: los emails se redirigen a este address en vez de enviarse
# al destinatario real. Defensa contra emails accidentales a clientes.
EMAIL_STAGING_REDIRECT=

# -------------------------------------------------------------------
# Lyrics reference (optional, improves /transcribe UX)
# -------------------------------------------------------------------
GENIUS_TOKEN=

# -------------------------------------------------------------------
# Whisper tuning
# -------------------------------------------------------------------
# 0 para deshabilitar el large-v3 fallback en transcripciones sparse.
WHISPER_FALLBACK_ENABLED=1

# -------------------------------------------------------------------
# Reaper / background sweeps
# -------------------------------------------------------------------
# Job se considera "orphan polling" si la última AI call tiene
# duration_ms NULL más vieja que este threshold. Más bajo = más
# agresivo recuperando jobs colgados por worker death.
REAPER_ORPHAN_POLL_THRESHOLD_MIN=10

# -------------------------------------------------------------------
# Feature flags (dormant / experimentales)
# -------------------------------------------------------------------
# Cuando true, el text layer se compone con ffmpeg overlay filters
# (rápido) en vez de moviepy CompositeVideoClip (lento). Off por
# default; activar solo cuando esté validado en staging.
USE_FFMPEG_TEXT_LAYER=false

# -------------------------------------------------------------------
# UMG Compliance
# -------------------------------------------------------------------
REQUIRE_REVIEW=true
SEND_ARTIST_TO_AI=true
VERTEX_ENTERPRISE_CONFIRMED=false

# -------------------------------------------------------------------
# Railway-specific
# -------------------------------------------------------------------
# SIGTERM→SIGKILL grace period en segundos. Default Railway: 30s,
# pero RQ workers necesitan ≥180s para drain in-flight Veo poll
# (60-120s típicos).
RAILWAY_SHUTDOWN_TIMEOUT_SECONDS=180

# -------------------------------------------------------------------
# Test environment (no setear en prod)
# -------------------------------------------------------------------
# Si está seteado, los tests con marker @pytest.mark.postgres corren
# contra este DSN. En CI ya está configurado al postgres service del
# workflow (.github/workflows/ci.yml).
# DATABASE_URL=postgresql://test:test@localhost:5432/lyricgen_test
