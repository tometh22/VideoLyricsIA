# ============================================================
# GenLy AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# ============================================================

# --- Database ---
POSTGRES_PASSWORD=change-this-in-production
DATABASE_URL=postgresql://genly:change-this-in-production@localhost:5432/genly

# --- Auth ---
JWT_SECRET=generate-a-strong-random-secret-here
ADMIN_PASSWORD=change-this-in-production
ADMIN_EMAIL=admin@yourcompany.com

# --- Frontend ---
FRONTEND_URL=https://app.genly.ai
CORS_ORIGINS=https://app.genly.ai

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create these prices in Stripe Dashboard → Products
STRIPE_PRICE_100=price_...
STRIPE_PRICE_250=price_...
STRIPE_PRICE_500=price_...
STRIPE_PRICE_1000=price_...

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=GenLy AI <noreply@genly.ai>

# --- Google AI (Vertex AI for backgrounds) ---
GOOGLE_APPLICATION_CREDENTIALS=/app/backend/vertex_credentials.json
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1

# --- YouTube API ---
YOUTUBE_TOKEN_PATH=/app/backend/youtube_token.json
YOUTUBE_OAUTH_PATH=/app/backend/youtube_oauth.json

# --- Sentry (error monitoring) ---
SENTRY_DSN=https://xxxx@o1234.ingest.sentry.io/5678
SENTRY_ENV=production
SENTRY_TRACES_RATE=0.1

# --- S3 Storage (optional — default: local disk) ---
STORAGE_BACKEND=local
# Set to "s3" and fill below to use S3/DigitalOcean Spaces/MinIO:
# S3_BUCKET=genly-outputs
# S3_REGION=us-east-1
# S3_ACCESS_KEY=AKIA...
# S3_SECRET_KEY=...
# S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com  # for DO Spaces

# --- Logging ---
LOG_LEVEL=INFO
SQL_ECHO=false
SHOW_DOCS=true
